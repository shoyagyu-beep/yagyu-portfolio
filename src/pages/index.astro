---
// src/pages/index.astro
import Site from '../layouts/Site.astro';
import type { Project } from '../types';

let projects: Project[] = [];
let latestNote: { type: string; date: string } | undefined;
try {
  const { getProjects, getNotes } = await import('../lib/microcms');
  [projects, latestNote] = await Promise.all([
    getProjects().then(p => p),
    getNotes().then(n => n[0]),
  ]);
} catch {
  // No credentials yet
}
---

<Site title="YAGYU SHAW" currentPath="/">
  <ul slot="left-list" class="home-list" role="list">
    {projects.map((p) => (
      <li>
        <a
          href={`/projects/${p.id}`}
          class="project-link"
          data-cover={p.coverImage?.url ?? ''}
          data-cover-alt={p.name}
        >
          {p.name}
          {p.category === 'commercial' && <span class="comm-label">comm.</span>}
        </a>
      </li>
    ))}
    {latestNote && (
      <li class="note-item">
        <a href="/notes" class="note-link">
          → {latestNote.type} {latestNote.date}
        </a>
      </li>
    )}
  </ul>

  <div slot="right-content" class="hover-stage" aria-hidden="true">
    <div class="hover-img-wrap" id="hover-img-wrap">
      <img id="hover-img" src="" alt="" class="hover-img" />
    </div>
  </div>
</Site>

<style>
  .home-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .project-link {
    font-family: var(--font-ja);
    font-size: 0.9rem;
    color: var(--color-ink);
    display: block;
    transition: color 0.15s;
  }

  .project-link:hover {
    color: var(--color-muted);
  }

  .comm-label {
    font-family: var(--font-latin);
    font-size: 0.65rem;
    color: var(--color-muted);
    margin-left: 0.4rem;
    letter-spacing: 0.03em;
  }

  .note-item {
    margin-top: 1rem;
  }

  .note-link {
    font-family: var(--font-latin);
    font-size: 0.8rem;
    color: var(--color-muted);
    transition: color 0.15s;
  }

  .note-link:hover {
    color: var(--color-ink);
  }

  .hover-stage {
    position: absolute;
    inset: 0;
  }

  .hover-img-wrap {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .hover-img-wrap.visible {
    opacity: 1;
  }

  .hover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('.project-link[data-cover]');
  const wrap = document.getElementById('hover-img-wrap') as HTMLDivElement;
  const img = document.getElementById('hover-img') as HTMLImageElement;

  if (wrap && img) {
    links.forEach((link) => {
      const src = link.dataset.cover ?? '';
      const alt = link.dataset.coverAlt ?? '';
      if (src) {
        const pre = new Image();
        pre.src = src;
      }
      link.addEventListener('mouseenter', () => {
        if (!src) return;
        img.src = src;
        img.alt = alt;
        wrap.classList.add('visible');
      });
      link.addEventListener('mouseleave', () => {
        wrap.classList.remove('visible');
      });
      link.addEventListener('touchstart', () => {
        if (!src) return;
        img.src = src;
        img.alt = alt;
        wrap.classList.add('visible');
      }, { passive: true });
      link.addEventListener('touchend', () => {
        wrap.classList.remove('visible');
      });
    });
  }
</script>
